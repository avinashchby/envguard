{
  "name": "@avinashchby/envguard",
  "version": "0.1.0",
  "description": "Validate, sync, and secure .env files",
  "license": "MIT",
  "bin": {
    "envguard": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
